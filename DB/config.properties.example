# Configuration de la base de données PostgreSQL
# Modifiez ces valeurs selon votre installation
db.url=jdbc:postgresql://localhost:5432/gemstones
db.username=postgres
db.password=rootdest

# Mettre à false après la première exécution pour ne plus recréer le schéma
db.create.schema=true

# Répertoire pour stocker les images téléchargées
images.directory=images

# Répertoires des fichiers à importer
# Placez vos fichiers Excel et HTML dans ces répertoires
import.excel.directory=data
import.html.directory=data
